# --- Compartido ---
PORT=3000
MONGO_URI=mongodb://localhost:27017/WherEXdb
# Opcional: nombre de la base (si no, se usa el del path del URI)
# MONGO_DB_NAME=WherEXdb
POLL_INTERVAL_MIN=5                     # fallback si no se define por integración

# --- Integración Jira ---
JIRA_BASE_URL=https://tu-org.atlassian.net
JIRA_EMAIL=tu-cuenta@tu-org.com
JIRA_API_TOKEN=ATATTxxxxx
JIRA_PROJECT_KEY=PROJ
JIRA_TRANSITION_DONE_ID=
# Opcional: override del POLL_INTERVAL_MIN solo para Jira
# JIRA_POLL_INTERVAL_MIN=5
# HubSpot (private app para Jira; pestana Auth -> "Show secret" para APP_SECRET)
JIRA_HUBSPOT_TOKEN=pat-na1-xxxxx
JIRA_HUBSPOT_APP_SECRET=
# Obten los 3 IDs con: node bin/jira/list-hubspot-ticket-stages.js
JIRA_HUBSPOT_PIPELINE_ID=
JIRA_HUBSPOT_STAGE_NEW_ID=
JIRA_HUBSPOT_STAGE_CLOSED_ID=

# --- Integración Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXX
# Opcional: override del POLL_INTERVAL_MIN solo para Slack
# SLACK_POLL_INTERVAL_MIN=5
# HubSpot (private app para Slack; pestana Auth -> "Show secret" para APP_SECRET)
SLACK_HUBSPOT_TOKEN=pat-na1-...
SLACK_HUBSPOT_APP_SECRET=
SLACK_HUBSPOT_PIPELINE_ID=0
SLACK_HUBSPOT_STAGE_NEW_ID=1
SLACK_HUBSPOT_STAGE_COMPLETED_ID=4